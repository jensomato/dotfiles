auto-reload yes
reload-time 5 # minutes
reload-threads 10

bind-key LEFT quit
bind-key RIGHT open
bind-key j down
bind-key k up
bind-key h quit
bind-key l open
bind-key d pagedown
bind-key u pageup
bind-key U show-urls

browser linkhandler
