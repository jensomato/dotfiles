urls-source "freshrss"
freshrss-url "{{ (passFields "intranet/freshrss").url }}/api/greader.php"
freshrss-login "{{ (passFields "intranet/freshrss").user }}"
freshrss-passwordeval "pass show passphrase/default"
freshrss-min-items 100
freshrss-flag-star "s"

#color listnormal         color15 default
#color listnormal_unread  color2  default
#color listfocus_unread   color2  color15
#color listfocus          default color15
#color background         default default
#color article            default default
#color end-of-text-marker color8  default
#color info               color4  color7
#color hint-separator     default color7
#color hint-description   default color7
#color title              color14 color7
#
#highlight article "^(Feed|Title|Author|Link|Date): .+" color4 default bold
#highlight article "^(Feed|Title|Author|Link|Date):" color14 default bold
#
#highlight article "\\((link|image|video)\\)" color8 default
#highlight article "https?://[^ ]+" color4 default
#highlight article "\[[0-9]+\]" color6 default bold

