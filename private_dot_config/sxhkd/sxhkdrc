super + d
	rofi -columns 2 -show-icons true -show drun -display-drun "Application 🖥️ "

button10
	WORD="$(xsel -o -p)"; goldendict -s "$WORD"

super + shift + d
	WORD="$(xsel -o -p)"; goldendict -s "$WORD"

super + p
	$HOME/.local/bin/rofi-pass

super + t
	$HOME/.local/bin/todofi.sh

super + shift t
	$HOME/.local/bin/todofi.sh -a

super + b
	rofi -modi "conf":"$HOME/.local/src/rofi-json/rofi-json.sh $XDG_CONFIG_HOME/rofi/tui-config.json" -matching fuzzy -show "conf"

super + g
	~/.local/bin/goto

super + shift + g
        rofi -show bookmark -modes "bookmark:$HOME/.local/scripts/rofi/rofibookmarks.sh $(ls -1 -t $BOOKMARKS_DIR/bookmarks/*.html | head -1)" -theme nord2 -kb-custom-1 "Ctrl+Return" -kb-accept-custom ""

super + c
	LC_NUMERIC=de_DE.UTF-8 rofi -plugin-path $XDG_CONFIG_HOME/rofi/plugins -show calc -modes calc -reuse-result -terse -no-sort -no-show-match -theme calc.rasi -calc-command "echo -n '{result}' | xclip -i -selection clipboard"

super + i
	$HOME/.local/scripts/i3/i3menu.sh

super + r ; super + d
        notify-send "test"

# enter fullscreen mode for the focused container
super + f
	i3-msg fullscreen toggle

# toggle tiling / floating
super + shift + space
	i3-msg floating toggle

# change focus between tiling / floating windows
super + space
	i3-msg focus mode_toggle

# focus the parent container
super + a
	i3-msg focus parent

# focus the child container
super + shift + a
	i3-msg focus child

# scratchpad
super + m
	i3-msg move scratchpad

# show scratchpad terminal
super + alt + ctrl + shift + F12
  ~/.local/scripts/i3/scratchpad_terminal.sh

super + s
  ~/.local/scripts/i3/scratchpads.sh

super + shift + s
  snippy

super + shift + l ; {t,m}
  { \
  ~/.local/scripts/i3/scratchpads.sh terminal, \
  ~/.local/scripts/i3/scratchpads.sh mail \
  }

F19
  snippy

XF86MonBrightnessDown
  ~/.local/bin/brightness-amdgpu decrease

XF86MonBrightnessUp
  ~/.local/bin/brightness-amdgpu increase

# show windows selector
alt + Tab
	rofi -show window

# Scratchpadded Apps
super + n
	i3-msg '[con_mark="notes"] scratchpad show, move position center'

super + z
	i3-msg '[con_mark="zim"] scratchpad show, move position center'

super + u
	i3-msg 'move scratchpad, scratchpad show'

super + l
	$HOME/.local/scripts/i3/i3system.sh

##
## i3 config
##

# change focus
super + {Left,Down,Up,Right}
	i3-msg focus {left,down,up,right}

# move focused window
super + shift + {Left,Down,Up,Right}
	i3-msg move {left,down,up,right}

# switch to workspace
super + alt + ctrl + {1-9,0}
	i3-msg workspace $I3_WS{1-9,10}

super + Tab
	i3-msg workspace back_and_forth

# move focused container to workspace
super + alt + ctrl + shift + {1-9,0}
	i3-msg move container to workspace $I3_WS{1-9,10}

super + i
	$HOME/.local/scripts/i3/i3menu.sh

# kill focused window
super + shift + q
	i3-msg kill

