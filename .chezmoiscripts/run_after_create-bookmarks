#!/bin/bash

# Exit script on any error
set -e

# Function to URL decode a string
urldecode() {
    local url_encoded="$1"
    # Replace '+' with space and decode hex values
    echo -e "$(echo "$url_encoded" | sed 's/+/ /g;s/%/\\x/g')"
}

# The input file
input_file="$HOME/.config/gtk-3.0/bookmarks"

# Set the target directory for the symlinks
bookmark_dir="$HOME/.local/share/bookmarks"

# Ensure the directory exists
mkdir -p "$bookmark_dir"

# Remove existing symlinks in the target directory
find "$bookmark_dir" -type l -exec rm {} +

# Read the file line by line
while IFS=" " read -r url title; do
    # Remove the "file://" prefix from the URL
    encoded_path="${url#file://}"

    # Decode the URL-encoded path
    path=$(urldecode "$encoded_path")

    # Create the symlink in the target directory
    ln -s "$path" "$bookmark_dir/$title"
done < "$input_file"

echo "Symlinks created successfully in $bookmark_dir"
