#!/bin/bash

DEFAULT_AMOUNT=10
CURRENT_BRIGHTNESS=$(cat /sys/class/backlight/amdgpu_bl0/brightness)
MAX_BRIGHTNESS=$(cat /sys/class/backlight/amdgpu_bl0/max_brightness)


if [ -z "$2" ]; then
  AMOUNT=$DEFAULT_AMOUNT
else
  AMOUNT="$2"
fi

if [ "$1" == "increase" ]; then
  NEW_BRIGHTNESS=$((CURRENT_BRIGHTNESS + AMOUNT))
elif [ "$1" == "decrease" ]; then
  NEW_BRIGHTNESS=$((CURRENT_BRIGHTNESS - AMOUNT))
else
  echo "Usage: $0 [increase|decrease] [amount (optional)]"
  exit 1
fi

if [ "$NEW_BRIGHTNESS" -gt $MAX_BRIGHTNESS ]; then
  NEW_BRIGHTNESS=$MAX_BRIGHTNESS
elif [ "$NEW_BRIGHTNESS" -lt 0 ]; then
  NEW_BRIGHTNESS=0
fi

echo "$NEW_BRIGHTNESS" > /sys/class/backlight/amdgpu_bl0/brightness
