#!/bin/bash

DEFAULT_AMOUNT=10
CURRENT_BRIGHTNESS=$(ddcutil getvcp 10 -b 7 | grep -oP 'current value =\s*\K[0-9]+')
MAX_BRIGHTNESS=100


if [ -z "$2" ]; then
  AMOUNT=$DEFAULT_AMOUNT
else
  AMOUNT="$2"
fi

if [ "$1" == "increase" ]; then
  NEW_BRIGHTNESS=$((CURRENT_BRIGHTNESS + AMOUNT))
elif [ "$1" == "decrease" ]; then
  NEW_BRIGHTNESS=$((CURRENT_BRIGHTNESS - AMOUNT))
else
  echo "Usage: $0 [increase|decrease] [amount (optional)]"
  exit 1
fi

if [ "$NEW_BRIGHTNESS" -gt $MAX_BRIGHTNESS ]; then
  NEW_BRIGHTNESS=$MAX_BRIGHTNESS
elif [ "$NEW_BRIGHTNESS" -lt 0 ]; then
  NEW_BRIGHTNESS=0
fi

ddcutil setvcp 10 "$NEW_BRIGHTNESS" --display 1
